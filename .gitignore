# =============================================================================
# ML / AI - Large Model & Dataset Files
# =============================================================================

# PyTorch models (có thể rất nặng)
*.pt
*.pth
*.onnx
*.tflite
*.pb
*.h5
*.hdf5
*.keras

# Pickle files - chỉ ignore pkl ngoài thư mục models
# (các model trong models/ được quản lý riêng bên dưới)
*.pickle

# Large datasets
DiQuaMuaHaa/backend/dataset/
DiQuaMuaHaa/backend/driver_training/dataset/
DiQuaMuaHaa/backend/driver_training/runs/
DiQuaMuaHaa/backend/driver_training/collect/data/landmarks_kaggle.csv
DiQuaMuaHaa/backend/data/

# Model weights folder
# - File nhỏ (<10MB): commit thẳng vào git
# - phone_model.pkl (101MB): dùng Git LFS
# - File .pth rỗng (chưa train): bỏ qua
DiQuaMuaHaa/backend/driver_training/models/*
!DiQuaMuaHaa/backend/driver_training/models/landmark_model.pkl
!DiQuaMuaHaa/backend/driver_training/models/hand_model.pkl
!DiQuaMuaHaa/backend/driver_training/models/smoking_model.pkl
!DiQuaMuaHaa/backend/driver_training/models/phone_yolo.pt
!DiQuaMuaHaa/backend/driver_training/models/phone_model.pkl

