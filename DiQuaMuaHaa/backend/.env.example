# Copy file này thành .env và điền thông tin thực
# cp .env.example .env

# MySQL local
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here
MYSQL_DATABASE=diquamuaha

# JWT Secret (đặt bất kỳ chuỗi ngẫu nhiên dài)
JWT_SECRET_KEY=your-secret-key-change-this

# Chỉ dùng khi deploy lên Render (PostgreSQL)
# DATABASE_URL=postgresql://user:pass@host/db
